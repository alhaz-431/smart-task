{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".", 
    "moduleDetection": "force"
  },
  "include": ["src/**/*"] 
}